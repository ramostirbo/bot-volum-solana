# --- Wallet and Network Settings ---
# المفتاح الخاص للمحفظة الأساسية (Base58)
PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# --- Network Selection (قم بإلغاء التعليق عن الشبكة المطلوبة) ---

# [ Solana Mainnet ]
# RPC_ENDPOINT=https://api.mainnet-beta.solana.com
# RPC_WEBSOCKET_ENDPOINT=wss://api.mainnet-beta.solana.com

# [ Solana Devnet (Test Network) ]
RPC_ENDPOINT=https://api.devnet.solana.com
RPC_WEBSOCKET_ENDPOINT=wss://api.devnet.solana.com

# --- Round Timing (إستراتيجية زمنية متوازنة) ---
DISTRIBUTE_INTERVAL_MAX=120
DISTRIBUTE_INTERVAL_MIN=60

# --- Trading Strategy (Volume Shaping) ---
BUY_UPPER_PERCENT=40
BUY_LOWER_PERCENT=20
BUY_INTERVAL_MAX=8
BUY_INTERVAL_MIN=2
SELL_INTERVAL_MAX=10
SELL_INTERVAL_MIN=4

# --- Distribution Settings ---
DISTRIBUTE_WALLET_NUM=10
SOL_AMOUNT_TO_DISTRIBUTE=0.15

# --- Token and Execution Settings ---
SLIPPAGE=15
TOKEN_MINT=YOUR_TOKEN_MINT_HERE

# تفعيل وضع Jito
JITO_MODE=false
JITO_FEE=0.0001
