# --- Wallet and Network Settings ---
# المفتاح الخاص للمحفظة الأساسية (Base58)
PRIVATE_KEY=

# --- Network Selection (قم بإلغاء التعليق عن الشبكة المطلوبة) ---

# [ Solana Mainnet ]
#RPC_ENDPOINT=https://api.mainnet-beta.solana.com
#RPC_WEBSOCKET_ENDPOINT=wss://api.mainnet-beta.solana.com

# [ Solana Devnet (Test Network) ]
RPC_ENDPOINT=https://api.devnet.solana.com
RPC_WEBSOCKET_ENDPOINT=wss://api.devnet.solana.com

# --- Round Timing (إستراتيجية هجومية لرفع الحجم والترند) ---
# وقت انتظار قصير جداً بين الجولات لضمان استمرارية النشاط
DISTRIBUTE_INTERVAL_MAX=30
DISTRIBUTE_INTERVAL_MIN=10

# --- Trading Strategy (Aggressive Volume & Stealth) ---
# رفع نسب الشراء لزيادة الشموع الخضراء في الشارت
BUY_UPPER_PERCENT=80
BUY_LOWER_PERCENT=40

# تقليل فترات الانتظار لزيادة وتيرة المعاملات في الثانية (TPS)
BUY_INTERVAL_MAX=3
BUY_INTERVAL_MIN=1

SELL_INTERVAL_MAX=5
SELL_INTERVAL_MIN=2

# --- Distribution Settings (أقصى قدرة لتوزيع السيولة) ---
# رفع عدد المحافظ لزيادة عدد "المتداولين الفريدين" (Unique Holders/Traders)
DISTRIBUTE_WALLET_NUM=5
# رفع كمية التوزيع لزيادة حجم التداول الإجمالي (Volume)
SOL_AMOUNT_TO_DISTRIBUTE=0.5

# --- Token and Execution Settings ---
# سليبج معقول لضمان نجاح الصفقات في التقلبات العالية
SLIPPAGE=100

# عنوان العملة (Mint Address)
TOKEN_MINT=8GC4kBVgREoeQcZJAr1prxtfqW67RSu411aCqeaCpump

# --- Professional Features Settings ---
# تفعيل المشتريات الصغيرة (Micro-buys) لرفع الترتيب في DexScreener
MICRO_BUY_ENABLED=true
# كمية صغيرة جداً لخلق آلاف المعاملات بتكلفة ضئيلة
MICRO_BUY_AMOUNT=0.0005
# بيع جزئي لترك رصيد (Dust) في المحافظ لإظهار زيادة في عدد الـ Holders
PARTIAL_SELL_PERCENT=90
# أقل وقت للاحتفاظ بالعملة (بالدقائق)
MIN_HOLD_TIME=1

# خيار الاحتفاظ بالمحافظ وإعادة استخدامها (true للحفاظ عليها، false لتوليد جديد دائماً)
REUSE_WALLETS=true

# --- Sniper Configuration ---
SNIPER_WALLET_NUM=3
SNIPER_SOL_AMOUNT=0.1

# --- Market Maker Configuration ---
MM_BUY_DIP_THRESHOLD=5       # شراء عندما يهبط السعر بنسبة 5%
MM_SELL_PEAK_THRESHOLD=8     # بيع عندما يرتفع السعر بنسبة 8%
MM_MIN_SOL_BALANCE=0.05      # الحد الأدنى من SOL المتبقي في المحفظة
MM_TRADE_AMOUNT_SOL=0.02     # كمية كل صفقة Market Making

# تفعيل وضع Jito (لا يعمل عادة على Devnet)
JITO_MODE=false
# رسوم الـ Jito (Tip)
JITO_FEE=0.0001
